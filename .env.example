# 複製此檔為 .env 後填入實際值。.env 已被 git 忽略,不會上傳。
# Windows: copy .env.example .env

# Ollama 伺服器網址(結尾不要加斜線)
OLLAMA_HOST=https://your-lab-ollama-host

# API key(機密,切勿提交到 GitHub)
OLLAMA_API_KEY=your-api-key-here

# 生成模型(依伺服器實際提供的為準)
LLM_MODEL=qwen2.5:7b

# Embedding:backend=local 用本機 sentence-transformers(預設,推薦)
# 若伺服器有 bge-m3 等專用 embedding 模型,可改 EMBED_BACKEND=ollama 並設 EMBED_MODEL
EMBED_BACKEND=local
LOCAL_EMBED_MODEL=BAAI/bge-m3
